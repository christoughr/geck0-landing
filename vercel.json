{
  "crons": [
    {
      "path": "/api/cron/sync",
      "schedule": "0 3 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/v1/:path*",
      "has": [{ "type": "host", "value": "api.geck0.ai" }],
      "destination": "/api/v1/:path*"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "api.geck0.ai" }],
      "destination": "https://geck0.ai/docs/api",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "app.geck0.ai" }],
      "destination": "/app",
      "permanent": false
    },
    {
      "source": "/login",
      "destination": "https://app.geck0.ai/app",
      "permanent": false
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "geck0-landing.vercel.app"
        }
      ],
      "destination": "https://geck0.ai/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "geck0.info"
        }
      ],
      "destination": "https://geck0.ai/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.geck0.info"
        }
      ],
      "destination": "https://geck0.ai/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "app.geck0.info" }],
      "destination": "https://geck0.ai/login",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.geck0.ai" }],
      "destination": "https://geck0.ai/:path*",
      "permanent": true
    }
  ]
}