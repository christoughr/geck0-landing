{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "geck0-landing.vercel.app"
        }
      ],
      "destination": "https://geck0.ai/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "geck0.info"
        }
      ],
      "destination": "https://geck0.ai/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.geck0.info"
        }
      ],
      "destination": "https://geck0.ai/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "app.geck0.info" }],
      "destination": "https://geck0.ai/login",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.geck0.ai" }],
      "destination": "https://geck0.ai/:path*",
      "permanent": true
    }
  ]
}