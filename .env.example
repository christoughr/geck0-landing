# Site
NEXT_PUBLIC_SITE_URL=https://geck0.ai
NEXT_PUBLIC_APP_URL=https://app.geck0.ai

# Analytics — Plausible (loads only after cookie consent)
NEXT_PUBLIC_PLAUSIBLE_SCRIPT_URL=https://plausible.io/js/pa-r5l7c00Z9HHInZ4nioefA.js

# Mailchimp waitlist (required for subscribe API in production)
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
MAILCHIMP_SERVER_PREFIX=
# Set to true for GDPR double opt-in (pending status)
MAILCHIMP_DOUBLE_OPTIN=true

# Contact persistence (at least one recommended for production)
SLACK_WEBHOOK_URL=
BLOB_READ_WRITE_TOKEN=

# Cloudflare Turnstile (recommended — set BOTH keys together)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Upstash Redis — distributed rate limiting (recommended for production)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Vercel KV (alternative names, auto-injected by Vercel KV integration)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Analytics
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_BETA_COUNT=47

# Sentry error monitoring (optional)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Admin API key for GET /api/subscribe status check
ADMIN_API_KEY=
